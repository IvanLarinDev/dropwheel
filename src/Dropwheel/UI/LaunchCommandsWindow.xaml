<Window x:Class="Dropwheel.UI.LaunchCommandsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launch commands - Dropwheel" Width="820" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Topmost="True"
        MinWidth="720" MinHeight="430">
    <Window.Resources>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Restore defaults" Style="{StaticResource ToolButton}" Click="OnRestoreDefaults"/>
            <Button Content="Cancel" Style="{StaticResource ToolButton}" Click="OnCancel"/>
            <Button Content="Apply" Style="{StaticResource ToolButton}" Click="OnApply"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Commands" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Add" Style="{StaticResource ToolButton}" Click="OnAdd"/>
                    <Button Content="Delete" Style="{StaticResource ToolButton}" Click="OnDelete"/>
                </StackPanel>
                <ListBox x:Name="CommandList" SelectionChanged="OnSelectionChanged"/>
            </DockPanel>

            <Border Grid.Column="2" x:Name="DetailPanel" BorderThickness="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Extensions" FontSize="12"/>
                            <TextBox x:Name="ExtensionsBox" Margin="0,4,0,0" TextChanged="OnEditChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Program" FontSize="12"/>
                            <TextBox x:Name="ProgramBox" Margin="0,4,0,0" TextChanged="OnEditChanged"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <TextBlock Text="Arguments" FontSize="12"/>
                        <TextBox x:Name="ArgumentsBox" Margin="0,4,0,0" TextChanged="OnEditChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="{}{target}" FontFamily="Consolas" Margin="0,0,16,0"/>
                        <TextBlock Text="{}{files}" FontFamily="Consolas" Margin="0,0,16,0"/>
                        <Button Content="Preview" Padding="10,2" Click="OnPreview"/>
                    </StackPanel>

                    <Border Grid.Row="3" x:Name="PreviewPanel" BorderThickness="1" Padding="12">
                        <TextBlock x:Name="PreviewText" FontFamily="Consolas" TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Grid.Row="4" x:Name="StatusText" TextWrapping="Wrap" Margin="0,12,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
