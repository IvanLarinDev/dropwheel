<Window x:Class="Dropwheel.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dropwheel" Width="460" Height="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False"
        ResizeMode="NoResize">
    <Canvas x:Name="Root">
        <Canvas x:Name="Cloud"/>
        <Grid x:Name="Orb" Width="46" Height="46" Canvas.Left="207" Canvas.Top="207"
              AllowDrop="True" Cursor="Hand" Background="Transparent">
            <Ellipse x:Name="OrbBall">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.35,0.3">
                        <GradientStop Color="#6FB6FF" Offset="0"/>
                        <GradientStop Color="#2F6FD0" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.6"/>
                </Ellipse.Effect>
            </Ellipse>
        </Grid>
        <Border x:Name="Toast" Canvas.Left="90" Canvas.Top="412" Visibility="Collapsed"
                Background="#E6161E2C" CornerRadius="8" Padding="10,6" MaxWidth="280">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastText" Foreground="White" FontSize="12"
                           TextTrimming="CharacterEllipsis" MaxWidth="210"/>
                <TextBlock x:Name="UndoLink" Text="  Undo" Foreground="#7CC4FF" FontSize="12"
                           FontWeight="SemiBold" Cursor="Hand" Visibility="Collapsed"
                           MouseLeftButtonUp="OnUndoClick"/>
            </StackPanel>
        </Border>
    </Canvas>
</Window>
