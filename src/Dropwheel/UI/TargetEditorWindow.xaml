<Window x:Class="Dropwheel.UI.TargetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Target — Dropwheel" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Topmost="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Width="280">
                <TextBlock Text="Name"/>
                <TextBox x:Name="NameBox" Margin="0,4,0,10"/>
                <TextBlock Text="Path (folder or .exe)"/>
                <DockPanel Margin="0,4,0,10">
                    <Button Content="…" Width="28" DockPanel.Dock="Right" Margin="6,0,0,0" Click="OnBrowse"/>
                    <TextBox x:Name="PathBox"/>
                </DockPanel>
                <TextBlock Text="Action on file drop"/>
                <ComboBox x:Name="ActionBox" Margin="0,4,0,10">
                    <ComboBoxItem Content="Default (global setting)"/>
                    <ComboBoxItem Content="Always copy"/>
                    <ComboBoxItem Content="Always move"/>
                </ComboBox>
                <TextBlock x:Name="GroupLabel" Text="Group"/>
                <ComboBox x:Name="GroupCombo" Margin="0,4,0,10"/>
                <CheckBox x:Name="PinBox" Content="Pin closer to center" Margin="0,0,0,10"/>
                <Button x:Name="ConvertBtn" Content="Convert to routing rules" Click="OnConvertToRules"
                        Padding="8,4" HorizontalAlignment="Left"/>
            </StackPanel>

            <StackPanel x:Name="MasterPanel" Grid.Column="1" Width="210" Margin="16,0,0,0"
                        Visibility="Collapsed">
                <TextBlock Text="Routing rules" FontWeight="SemiBold"/>
                <TextBlock Text="first match wins" FontSize="11" Foreground="Gray" Margin="0,1,0,6"/>
                <ScrollViewer MaxHeight="230" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="MasterHost"/>
                </ScrollViewer>
                <DockPanel Margin="0,8,0,0">
                    <Button Content="Presets ▾" Click="OnPresetsClick" DockPanel.Dock="Right" Padding="8,2"/>
                    <Button Content="+ Rule" Click="OnAddRule" Padding="8,2" HorizontalAlignment="Left"/>
                </DockPanel>
                <TextBlock Text="Test files (one path per line)" Margin="0,12,0,4"/>
                <TextBox x:Name="PreviewInput" AcceptsReturn="True" Height="54"
                         VerticalScrollBarVisibility="Auto" TextChanged="OnPreviewChanged"/>
            </StackPanel>

            <Border x:Name="DetailPanel" Grid.Column="2" Width="330" Margin="16,0,0,0"
                    Visibility="Collapsed" BorderBrush="#22000000" BorderThickness="1"
                    CornerRadius="6" Padding="10">
                <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailHost"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <DockPanel Grid.Row="1" Margin="0,14,0,0">
            <Button Content="Delete target" Click="OnDelete" DockPanel.Dock="Left"
                    Foreground="Firebrick" Padding="8,4"/>
            <Button Content="Save" Click="OnSave" Width="100" Padding="8,4"
                    HorizontalAlignment="Right"/>
        </DockPanel>
    </Grid>
</Window>
