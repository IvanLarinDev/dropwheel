<Window x:Class="Dropwheel.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Dropwheel.UI"
        Title="Settings — Dropwheel" Width="512" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True">
    <ui:DialogShell x:Name="Shell" Title="Settings" PrimaryText="Save">
        <Grid Height="336" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="SectionList" Grid.Column="0" BorderThickness="0"
                     Background="Transparent" Margin="0,0,14,0" SelectionChanged="OnSectionChanged">
                <ListBoxItem>
                    <DockPanel>
                        <Ellipse x:Name="WheelErrDot" DockPanel.Dock="Right" Width="7" Height="7"
                                 VerticalAlignment="Center" Visibility="Collapsed"
                                 Fill="{DynamicResource DwDanger}"/>
                        <TextBlock Text="Wheel behavior"/>
                    </DockPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <DockPanel>
                        <Ellipse x:Name="AppearanceErrDot" DockPanel.Dock="Right" Width="7" Height="7"
                                 VerticalAlignment="Center" Visibility="Collapsed"
                                 Fill="{DynamicResource DwDanger}"/>
                        <TextBlock Text="Appearance"/>
                    </DockPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <DockPanel>
                        <Ellipse x:Name="HotkeyErrDot" DockPanel.Dock="Right" Width="7" Height="7"
                                 VerticalAlignment="Center" Visibility="Collapsed"
                                 Fill="{DynamicResource DwDanger}"/>
                        <TextBlock Text="Hotkey &amp; shortcuts"/>
                    </DockPanel>
                </ListBoxItem>
                <ListBoxItem Content="System"/>
            </ListBox>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
                <Grid>
                    <StackPanel x:Name="WheelPanel">
                        <TextBlock Text="Default drop action"/>
                        <ComboBox x:Name="ActionBox" Margin="0,4,0,10">
                            <ComboBoxItem Content="Copy"/>
                            <ComboBoxItem Content="Move"/>
                        </ComboBox>
                        <TextBlock Text="Hover delay to open, ms"/>
                        <TextBox x:Name="HoverBox" Margin="0,4,0,0"/>
                        <TextBlock x:Name="HoverError" Text="Enter a whole number" FontSize="11"
                                   Foreground="{DynamicResource DwDanger}" Visibility="Collapsed"
                                   Margin="0,3,0,0"/>
                        <TextBlock Text="Wheel layout when a level has many targets" Margin="0,10,0,0"/>
                        <ComboBox x:Name="OverflowLayoutBox" Margin="0,4,0,10"/>
                        <TextBlock x:Name="OverflowThresholdLabel" Text="Extra ring appears after this many targets"/>
                        <TextBox x:Name="OverflowThresholdBox" Margin="0,4,0,0"
                                 ToolTip="How many targets the main ring holds before the extra ring appears. The + and Back tiles don't count. Range 4–16. Ignored for the None layout."/>
                        <TextBlock x:Name="ThresholdError" Text="Enter a whole number" FontSize="11"
                                   Foreground="{DynamicResource DwDanger}" Visibility="Collapsed"
                                   Margin="0,3,0,0"/>
                        <CheckBox x:Name="DeduplicateBox" Content="Skip duplicate targets on the wheel"
                                  Margin="0,12,0,4"
                                  ToolTip="When on, dropping a folder, app or link already on the current level highlights the existing tile instead of adding a copy."/>
                    </StackPanel>

                    <StackPanel x:Name="AppearancePanel" Visibility="Collapsed">
                        <TextBlock Text="Theme"/>
                        <ComboBox x:Name="ThemeBox" Margin="0,4,0,10"/>
                        <TextBlock Text="Open animation"/>
                        <Grid Margin="0,4,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="82"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="OpenAnimationBox" Grid.Column="0" Margin="0,0,10,0"/>
                            <Border x:Name="AnimPreviewBox" Grid.Column="1" BorderThickness="1" Height="31">
                                <Canvas x:Name="AnimPreviewDots">
                                    <Ellipse Width="7" Height="7" Canvas.Left="37" Canvas.Top="12"/>
                                    <Ellipse Width="6" Height="6" Opacity="0.8" Canvas.Left="20" Canvas.Top="6"/>
                                    <Ellipse Width="6" Height="6" Opacity="0.8" Canvas.Left="54" Canvas.Top="6"/>
                                    <Ellipse Width="5" Height="5" Opacity="0.55" Canvas.Left="12" Canvas.Top="21"/>
                                    <Ellipse Width="5" Height="5" Opacity="0.55" Canvas.Left="62" Canvas.Top="21"/>
                                </Canvas>
                            </Border>
                        </Grid>
                        <TextBlock Text="Animation speed"/>
                        <Grid Margin="0,4,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="OpenAnimationSpeedSlider" Grid.Column="0" Minimum="0.5" Maximum="2"
                                    TickFrequency="0.25" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                    Margin="0,0,10,0"/>
                            <TextBlock x:Name="OpenAnimationSpeedText" Grid.Column="1" VerticalAlignment="Center"
                                       TextAlignment="Right"/>
                        </Grid>
                        <TextBlock Text="Wheel size"/>
                        <Grid Margin="0,4,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="WheelScaleSlider" Grid.Column="0" Minimum="0.8" Maximum="1.5"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                    Margin="0,0,10,0"/>
                            <TextBlock x:Name="WheelScaleText" Grid.Column="1" VerticalAlignment="Center"
                                       TextAlignment="Right"/>
                        </Grid>
                        <TextBlock Text="Orb opacity"/>
                        <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1"
                                TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,4,0,10"/>
                        <TextBlock Text="Fade orb when idle, seconds (0 = off)"/>
                        <TextBox x:Name="IdleBox" Margin="0,4,0,0"/>
                        <TextBlock x:Name="IdleError" Text="Enter a whole number" FontSize="11"
                                   Foreground="{DynamicResource DwDanger}" Visibility="Collapsed"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="HotkeyPanel" Visibility="Collapsed">
                        <TextBlock Text="Global hotkey"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="64"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HotkeyBox" Grid.Column="0" IsReadOnly="True"
                                     ToolTip="Pick a combination from the chips below, or press Record for a custom one."/>
                            <Button x:Name="HotkeyCaptureButton" Grid.Column="1" Content="Record"
                                    Margin="8,0,0,0" Padding="8,3"
                                    ToolTip="Press a shortcut; Esc cancels."/>
                            <Button x:Name="HotkeyResetButton" Grid.Column="2" Content="Reset"
                                    Margin="8,0,0,0" Padding="8,3"/>
                        </Grid>
                        <TextBlock x:Name="HotkeyStatus" FontSize="11" Visibility="Collapsed" Margin="0,3,0,0"/>
                        <WrapPanel x:Name="HotkeyChips" Margin="0,7,0,0"/>
                        <TextBlock Text="Open at orb — second hotkey (optional)" Margin="0,12,0,0"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OrbHotkeyBox" Grid.Column="0" IsReadOnly="True"
                                     ToolTip="An optional second global shortcut that opens the wheel at the orb's home position, not at the cursor. Pick a chip below or press Record; Off disables it."/>
                            <Button x:Name="OrbHotkeyCaptureButton" Grid.Column="1" Content="Record"
                                    Margin="8,0,0,0" Padding="8,3"
                                    ToolTip="Press a shortcut; Esc cancels."/>
                        </Grid>
                        <TextBlock x:Name="OrbHotkeyStatus" FontSize="11" Visibility="Collapsed" Margin="0,3,0,0"/>
                        <WrapPanel x:Name="OrbHotkeyChips" Margin="0,7,0,0"/>
                        <TextBlock Text="Group shortcut sequence timeout, ms" Margin="0,10,0,0"/>
                        <TextBox x:Name="GroupShortcutDelayBox" Margin="0,4,0,0"
                                 ToolTip="Maximum pause between digits. Range: 150–1500 ms."/>
                        <TextBlock x:Name="DelayError" Text="Enter a whole number" FontSize="11"
                                   Foreground="{DynamicResource DwDanger}" Visibility="Collapsed"
                                   Margin="0,3,0,0"/>
                        <TextBlock Text="Fixed orb gestures" Margin="0,12,0,0"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Alt + drag"
                                       FontWeight="SemiBold" Margin="0,0,10,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Move the orb"
                                       Foreground="{DynamicResource DwTextMuted}" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Alt + Shift + drag"
                                       FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="Add a tile for the object under the cursor"
                                       Foreground="{DynamicResource DwTextMuted}" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="SystemPanel" Visibility="Collapsed">
                        <CheckBox x:Name="AutostartBox" Content="Start with Windows" Margin="0,2,0,4"/>
                        <TextBlock Text="Saved text file name (empty = text_&lt;date&gt;)" Margin="0,12,0,0"/>
                        <TextBox x:Name="TextNameBox" Margin="0,4,0,0"
                                 ToolTip="Template for dropped-text file names, without extension. Same ${name} tokens as sorter destinations: ${slug} (first line of the text), ${date} ${time} ${year} ${month} ${day}. Empty keeps text_yyyy-MM-dd_HH-mm-ss."/>
                        <TextBlock Text="Click a token to insert it (curly braces, with the $):" FontSize="11"
                                   Opacity="0.7" Margin="0,4,0,2"/>
                        <WrapPanel x:Name="TextNameChips"/>
                        <CheckBox x:Name="CopyDestBox" Content="Copy destination path to clipboard after a drop"
                                  Margin="0,14,0,4"
                                  ToolTip="After a successful drop, put the destination path on the clipboard so you can paste it straight away. The created file for a single saved file, or the destination folder otherwise."/>
                        <TextBlock Text="Toast duration, seconds (error/undo toasts last twice as long)" Margin="0,14,0,0"/>
                        <TextBox x:Name="ToastSecondsBox" Margin="0,4,0,0"
                                 ToolTip="How long a toast stays up before fading. 1–60. Hovering it pauses the timer."/>
                        <TextBlock x:Name="ToastSecondsError" Text="Enter a whole number 1–60" FontSize="11"
                                   Foreground="{DynamicResource DwDanger}" Visibility="Collapsed" Margin="0,3,0,0"/>
                        <CheckBox x:Name="ToastSoundBox" Content="Play a sound for warning and error toasts"
                                  Margin="0,10,0,4"
                                  ToolTip="A short system sound on Warning and Danger toasts only. Routine drops stay silent."/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </ui:DialogShell>
</Window>
