<Window x:Class="Dropwheel.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — Dropwheel" Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True">
    <StackPanel Margin="16">
        <TextBlock Text="Theme"/>
        <ComboBox x:Name="ThemeBox" Margin="0,4,0,10"/>
        <TextBlock Text="Open animation"/>
        <Grid Margin="0,4,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="82"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="OpenAnimationBox" Grid.Column="0" Margin="0,0,10,0"/>
            <Border x:Name="AnimPreviewBox" Grid.Column="1" BorderThickness="1" Height="31">
                <Canvas x:Name="AnimPreviewDots">
                    <Ellipse Width="7" Height="7" Canvas.Left="37" Canvas.Top="12"/>
                    <Ellipse Width="6" Height="6" Opacity="0.8" Canvas.Left="20" Canvas.Top="6"/>
                    <Ellipse Width="6" Height="6" Opacity="0.8" Canvas.Left="54" Canvas.Top="6"/>
                    <Ellipse Width="5" Height="5" Opacity="0.55" Canvas.Left="12" Canvas.Top="21"/>
                    <Ellipse Width="5" Height="5" Opacity="0.55" Canvas.Left="62" Canvas.Top="21"/>
                </Canvas>
            </Border>
        </Grid>
        <TextBlock Text="Animation speed"/>
        <Grid Margin="0,4,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="OpenAnimationSpeedSlider" Grid.Column="0" Minimum="0.5" Maximum="2"
                    TickFrequency="0.25" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                    Margin="0,0,10,0"/>
            <TextBlock x:Name="OpenAnimationSpeedText" Grid.Column="1" VerticalAlignment="Center"
                       TextAlignment="Right"/>
        </Grid>
        <TextBlock Text="Wheel layout when a level has many targets"/>
        <ComboBox x:Name="OverflowLayoutBox" Margin="0,4,0,10"/>
        <TextBlock x:Name="OverflowThresholdLabel" Text="Extra ring appears after this many targets"/>
        <TextBox x:Name="OverflowThresholdBox" Margin="0,4,0,10"
                 ToolTip="How many targets the main ring holds before the extra ring appears. The + and Back tiles don't count. Range 4–16. Ignored for the None layout."/>
        <TextBlock Text="Default drop action"/>
        <ComboBox x:Name="ActionBox" Margin="0,4,0,10">
            <ComboBoxItem Content="Copy"/>
            <ComboBoxItem Content="Move"/>
        </ComboBox>
        <TextBlock Text="Hover delay to open, ms"/>
        <TextBox x:Name="HoverBox" Margin="0,4,0,10"/>
        <TextBlock Text="Orb opacity"/>
        <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1"
                TickFrequency="0.05" IsSnapToTickEnabled="True" Margin="0,4,0,10"/>
        <TextBlock Text="Fade orb when idle, seconds (0 = off)"/>
        <TextBox x:Name="IdleBox" Margin="0,4,0,10"/>
        <TextBlock Text="Global hotkey (e.g. Ctrl+Alt+Space)"/>
        <TextBox x:Name="HotkeyBox" Margin="0,4,0,10"/>
        <TextBlock Text="Group shortcut sequence timeout, ms"/>
        <TextBox x:Name="GroupShortcutDelayBox" Margin="0,4,0,10"
                 ToolTip="Maximum pause between digits. Range: 150–1500 ms."/>
        <CheckBox x:Name="DeduplicateBox" Content="Skip duplicate targets on the wheel" Margin="0,4,0,4"
                  ToolTip="When on, dropping a folder, app or link already on the current level highlights the existing tile instead of adding a copy."/>
        <CheckBox x:Name="AutostartBox" Content="Start with Windows" Margin="0,4,0,14"/>
        <Button Content="Save" Width="100" Padding="8,4"
                HorizontalAlignment="Right" Click="OnSave"/>
    </StackPanel>
</Window>
