<Window x:Class="Dropwheel.UI.TokenHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Dropwheel.UI"
        Title="Destination tokens — Dropwheel" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Topmost="True">
    <ui:DialogShell x:Name="Shell" Title="Destination tokens"
                    Subtitle="Placeholders you can drop into a rule's Destination."
                    PrimaryText="Close" ShowCancel="False">
        <Grid Width="540" Height="300" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="CategoryList" Grid.Column="0" BorderThickness="0"
                     Background="Transparent" SelectionChanged="OnCategoryChanged"/>

            <Border Grid.Column="1" Margin="14,0,0,0" BorderBrush="{DynamicResource DwBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailHost" Margin="0,0,14,0"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </ui:DialogShell>
</Window>
