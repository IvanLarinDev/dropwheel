<Window x:Class="Dropwheel.UI.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Dropwheel"
        Width="640"
        Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        KeyboardNavigation.TabNavigation="Cycle"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="SetupCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource DwSurface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DwBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>
        <Style x:Key="SetupIcon" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource DwSelection}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="SetupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SetupNote" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource DwTextMuted}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="SetupSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="{DynamicResource DwBorder}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" Background="{TemplateBinding Background}" CornerRadius="12">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource DwAccent}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource DwAccent}"/>
                                <Setter TargetName="Track" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FooterButton" TargetType="Button">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>
        <Style x:Key="PrimaryFooterButton" TargetType="Button" BasedOn="{StaticResource FooterButton}">
            <Setter Property="Background" Value="{DynamicResource DwAccent}"/>
            <Setter Property="Foreground" Value="{DynamicResource DwAccentText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DwAccent}"/>
        </Style>
    </Window.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                  Focusable="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="62"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#20344F" Padding="20,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Ready in under a minute." Foreground="#F3F7FC"
                                   FontSize="21" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        <TextBlock Text="Your default wheel already has four useful destinations."
                                   Foreground="#B8C7D9" FontSize="11" Margin="0,8,0,0"
                                   TextWrapping="Wrap" LineHeight="17"/>
                    </StackPanel>
                    <Grid Grid.Row="1" Width="164" Height="164" VerticalAlignment="Bottom">
                        <Ellipse Stroke="#38506D" StrokeThickness="18"/>
                        <Ellipse Width="48" Height="48" Fill="#13263D" Stroke="#4DA3FF" StrokeThickness="7"/>
                        <Border Width="48" Height="48" CornerRadius="7" Background="#41546C"
                                BorderBrush="#74869A" BorderThickness="1" VerticalAlignment="Top">
                            <TextBlock Text="↓" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="48" Height="48" CornerRadius="7" Background="#41546C"
                                BorderBrush="#74869A" BorderThickness="1" HorizontalAlignment="Right">
                            <TextBlock Text="▧" Foreground="White" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="48" Height="48" CornerRadius="7" Background="#41546C"
                                BorderBrush="#74869A" BorderThickness="1" VerticalAlignment="Bottom">
                            <TextBlock Text="□" Foreground="White" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="48" Height="48" CornerRadius="7" Background="#41546C"
                                BorderBrush="#74869A" BorderThickness="1" HorizontalAlignment="Left">
                            <TextBlock Text="▤" Foreground="White" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="18,16,18,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,10">
                    <Border DockPanel.Dock="Right" Background="#E6F6ED" CornerRadius="10" Padding="8,3">
                        <TextBlock x:Name="ReadyCountText" Text="2 of 4 ready" Foreground="#147A41"
                                   FontSize="10" FontWeight="SemiBold"
                                   AutomationProperties.Name="Setup progress, 2 of 4 ready"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </Border>
                    <TextBlock Text="Quick setup" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>

                <Border Grid.Row="1" Style="{StaticResource SetupCard}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="Ready" Foreground="#168447"
                                   FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Style="{StaticResource SetupIcon}">
                            <TextBlock Text="✓" Foreground="#168447" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Default targets" Style="{StaticResource SetupTitle}"/>
                            <TextBlock Text="Downloads, Documents, Desktop, Pictures" Style="{StaticResource SetupNote}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource SetupCard}">
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Background="{DynamicResource DwSelection}" CornerRadius="4"
                                BorderBrush="{DynamicResource DwBorder}" BorderThickness="1" Padding="6,3" VerticalAlignment="Center">
                            <TextBlock Text="Ctrl+Alt+Space" FontFamily="Consolas" FontSize="9"/>
                        </Border>
                        <Border Style="{StaticResource SetupIcon}">
                            <TextBlock Text="⌨" Foreground="{DynamicResource DwAccent}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Open anywhere" Style="{StaticResource SetupTitle}"/>
                            <TextBlock Text="Change later in Hotkey &amp; shortcuts" Style="{StaticResource SetupNote}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="3" Style="{StaticResource SetupCard}">
                    <DockPanel>
                        <ToggleButton x:Name="ExplorerSendToToggle" DockPanel.Dock="Right"
                                      Style="{StaticResource SetupSwitch}" VerticalAlignment="Center"
                                      KeyboardNavigation.TabIndex="0"
                                      Checked="OnOptionChanged" Unchecked="OnOptionChanged"
                                      AutomationProperties.Name="Enable Explorer SendTo shortcut"
                                      AutomationProperties.HelpText="Adds Dropwheel to Explorer's Send to menu"/>
                        <Border Style="{StaticResource SetupIcon}">
                            <TextBlock Text="➤" Foreground="{DynamicResource DwAccent}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Explorer SendTo shortcut" Style="{StaticResource SetupTitle}"/>
                            <TextBlock Text="Send selected Explorer files to the wheel" Style="{StaticResource SetupNote}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource SetupCard}">
                    <DockPanel>
                        <ToggleButton x:Name="StartWithWindowsToggle" DockPanel.Dock="Right"
                                      Style="{StaticResource SetupSwitch}" VerticalAlignment="Center"
                                      KeyboardNavigation.TabIndex="1"
                                      Checked="OnOptionChanged" Unchecked="OnOptionChanged"
                                      AutomationProperties.Name="Start Dropwheel with Windows"
                                      AutomationProperties.HelpText="Launches Dropwheel after sign-in"/>
                        <Border Style="{StaticResource SetupIcon}">
                            <TextBlock Text="□" Foreground="{DynamicResource DwAccent}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Start with Windows" Style="{StaticResource SetupTitle}"/>
                            <TextBlock Text="Keep the orb ready after sign-in" Style="{StaticResource SetupNote}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <StackPanel Grid.Row="5" Margin="2,1,0,0" VerticalAlignment="Top">
                    <TextBlock Text="Finishing setup applies these choices to Windows. You can change either later from the tray menu."
                               Style="{StaticResource SetupNote}"/>
                    <TextBlock x:Name="ErrorText" Margin="0,5,0,0" Visibility="Collapsed"
                               Focusable="True" KeyboardNavigation.IsTabStop="False"
                               Foreground="{DynamicResource DwDanger}" TextWrapping="Wrap"
                               Text="Setup couldn't be saved. No completion was recorded; please try again."
                               AutomationProperties.Name="Setup could not be completed"
                               AutomationProperties.LiveSetting="Assertive"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BorderBrush="{DynamicResource DwBorder}" BorderThickness="0,1,0,0"
                Background="{DynamicResource DwSurface}">
            <DockPanel Margin="18,12">
                <Button x:Name="DecideLaterButton" DockPanel.Dock="Left" Content="_Decide later"
                        Style="{StaticResource FooterButton}" Background="Transparent" BorderThickness="0"
                        KeyboardNavigation.TabIndex="2" Click="OnDecideLater"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="OpenWheelButton" Content="_Open wheel" Margin="0,0,8,0"
                            Style="{StaticResource FooterButton}" KeyboardNavigation.TabIndex="3"
                            Click="OnOpenWheel"/>
                    <Button x:Name="FinishButton" Content="_Finish setup" MinWidth="108"
                            Style="{StaticResource PrimaryFooterButton}" IsDefault="True"
                            KeyboardNavigation.TabIndex="4" Click="OnFinish"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
