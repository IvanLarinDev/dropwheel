# Scripts must stay LF; CRLF in a shebang breaks macOS/Linux execution.
*.sh          text eol=lf
*.ps1         text eol=lf

# Config files are LF too: otherwise Windows with autocrlf=true makes the working
# tree CRLF and it diverges from the index and Linux CI. Pin these formats explicitly.
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.cmd   text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

# Default: normalize text, let git decide line endings on checkout for the rest.
* text=auto
